name: Mirror to GitLab

on:
  push:
    branches: ["**"]
    tags: ["**"]
  delete:

jobs:
  mirror:
    runs-on: ubuntu-latest
    steps:
      - name: Mirror clone and push
        env:
          GITLAB_TOKEN: ${{ secrets.GITLAB_TOKEN }}
          GITLAB_REPO:  ${{ secrets.GITLAB_REPO }}
          GH_REPO:      ${{ github.repository }}
        run: |
          set -euo pipefail

          # Mirror-clone from GitHub into a bare repo (no checked-out branch)
          git clone --mirror "https://github.com/${GH_REPO}.git" repo.git
          cd repo.git

          # Push mirror to GitLab
          TARGET="${GITLAB_REPO/https:\/\//https:\/\/oauth2:${GITLAB_TOKEN}@}"
          git push --mirror "$TARGET"
